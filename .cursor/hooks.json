{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "node ./.cursor/scripts/browser-devtools-hook.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "beforeMCPExecution": [
      {
        "type": "command",
        "command": "node ./.cursor/scripts/browser-devtools-hook.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterMCPExecution": [
      {
        "type": "command",
        "command": "node ./.cursor/scripts/browser-devtools-hook.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "node ./.cursor/scripts/browser-devtools-hook.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "command": "node ./.cursor/scripts/browser-devtools-hook.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterAgentResponse": [
      {
        "type": "command",
        "command": "node ./.cursor/scripts/browser-devtools-hook.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": "node ./.cursor/scripts/browser-devtools-hook.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ]
  }
}
